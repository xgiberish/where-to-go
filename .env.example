# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/where_to_go

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM strategy ──────────────────────────────────────────────────────────────
# Primary: Groq (free tier, fast)  https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: Gemini — for cost-demo / fallback  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Provider selection
PRIMARY_PROVIDER=groq
ENABLE_COST_DEMO=false   # true → route one call through Gemini for cost comparison

# Model configuration
CHEAP_MODEL=llama-3.1-8b-instant       # Groq tier-1: ultra-fast ($0.05/$0.08 per 1M, theoretical)
STRONG_MODEL=llama-3.3-70b-versatile   # Groq tier-2: smart    ($0.27/$0.27 per 1M, theoretical)
DEMO_MODEL=gemini-1.5-flash            # Gemini tier-3: cost demo ($0.075/$0.30 per 1M, actual)

# Theoretical pricing — used only for cost tracking/logs; Groq is free
GROQ_CHEAP_INPUT_PRICE=0.05
GROQ_CHEAP_OUTPUT_PRICE=0.08
GROQ_STRONG_INPUT_PRICE=0.27
GROQ_STRONG_OUTPUT_PRICE=0.27
GEMINI_FLASH_INPUT_PRICE=0.075
GEMINI_FLASH_OUTPUT_PRICE=0.30

# Optional fallbacks (leave empty if not needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Embeddings (Gemini text-embedding-004, 768 dims) ──────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# ── ML ────────────────────────────────────────────────────────────────────────
ML_MODEL_PATH=ml/models/travel_style_classifier.joblib

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_TIMEOUT=10

# ── Discord notifications (optional) ──────────────────────────────────────────
# Paste your Discord channel webhook URL to receive agent run notifications.
# Leave empty to disable. Get one from: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ── External APIs ─────────────────────────────────────────────────────────────
WEATHER_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# JSON list — add more origins as needed: ["http://localhost:5173","https://myapp.com"]
CORS_ORIGINS=["http://localhost:5173"]

# ── Test ──────────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/where_to_go_test
